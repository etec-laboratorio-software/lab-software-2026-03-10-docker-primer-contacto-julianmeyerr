# ============================================
# CONFIGURACIÓN DEL BACKEND - E-COMMERCE
# ============================================

# Puerto en el que corre el backend
PORT=4000

# URI de conexión a MongoDB
# Si usas Docker: mongodb://localhost:27017/ecommerce
# Si usas MongoDB Atlas: mongodb+srv://usuario:password@cluster.mongodb.net/ecommerce
MONGO_URI=mongodb://localhost:27017/ecommerce

# Clave secreta para firmar tokens JWT
# ⚠️ IMPORTANTE: Cambiar por una clave segura en producción
# Puedes generar una con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=clave_secreta_super_segura_cambiar_en_produccion

# Tiempo de expiración de los tokens JWT
# Ejemplos: 1h (1 hora), 1d (1 día), 7d (7 días)
JWT_EXPIRES_IN=1d

# Número de rondas de sal para bcrypt
# Mayor número = más seguro pero más lento
# Valores recomendados: 10-12
SALT_ROUNDS=10